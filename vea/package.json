{
  "name": "vue3-element-admin",
  "description": "Vue3 + Vite + TypeScript + Element-Plus 的后台管理模板，vue-element-admin 的 Vue3 版本",
  "version": "4.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint:eslint": "eslint --cache \"src/**/*.{vue,ts,js}\" --fix",
    "lint:prettier": "prettier --write \"**/*.{js,cjs,ts,json,css,scss,vue,html,md}\"",
    "lint:stylelint": "stylelint --cache \"**/*.{css,scss,vue}\" --fix",
    "lint:lint-staged": "lint-staged",
    "lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:stylelint",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{cjs,json}": [
      "prettier --write"
    ],
    "*.{vue,html}": [
      "eslint --fix",
      "prettier --write",
      "stylelint --fix"
    ],
    "*.{scss,css}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@vueuse/core": "^14.3.0",
    "@wangeditor-next/editor": "^5.7.7",
    "@wangeditor-next/editor-for-vue": "^5.1.14",
    "animate.css": "^4.1.1",
    "axios": "^1.16.1",
    "codemirror": "^5.65.21",
    "codemirror-editor-vue3": "^2.8.0",
    "default-passive-events": "^2.0.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.14.0",
    "exceljs": "^4.4.0",
    "html2pdf.js": "^0.14.0",
    "html5-qrcode": "^2.3.8",
    "lodash-es": "^4.18.1",
    "moment-timezone": "^0.6.2",
    "nprogress": "^0.2.0",
    "path-browserify": "^1.0.1",
    "path-to-regexp": "^8.4.2",
    "pinia": "^3.0.4",
    "qs": "^6.15.2",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.34",
    "vue-draggable-plus": "^0.6.1",
    "vue-files-preview": "^1.0.43",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "vxe-table": "~4.6.25"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@iconify/utils": "^3.1.3",
    "@types/codemirror": "^5.60.17",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@types/nprogress": "^0.2.3",
    "@types/path-browserify": "^1.0.3",
    "@types/qs": "^6.15.1",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.13.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-prettier": "^5.0.3",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "unocss": "^66.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.14",
    "vite-plugin-mock-dev-server": "^2.3.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.2"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}