# 应用端口
VITE_APP_PORT=8001
# 项目名称
VITE_APP_TITLE=Symfony8 Vue3 Admin
# 代理前缀
VITE_APP_BASE_API=/dev-api

# 接口地址
# VITE_APP_API_URL=https://api.youlai.tech     # 线上
# VITE_APP_API_URL=https://api.youlai.tech/v2    # 线上(多租户)
VITE_APP_API_URL=http://localhost:8101       # 本地


# 启用 Mock 服务(true:开启 false:关闭)
VITE_MOCK_DEV_SERVER=false

# 多租户开关(true:开启 false:关闭)
VITE_APP_TENANT_ENABLED=false
# 是否开启验证码(true/false)
VITE_USE_CAPTCHA=true

VITE_MERCURE_URL=http://localhost:3000/.well-known/mercure